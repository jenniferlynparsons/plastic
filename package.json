{
  "name": "plastic",
  "version": "1.0.0",
  "description": "A flexible text-based rpg engine built in JavaScript.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jenniferlynparsons/plastic.git"
  },
  "keywords": [
    "javascript",
    "rpg",
    "game-engine"
  ],
  "author": "Jennifer Lyn Parsons",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/jenniferlynparsons/plastic/issues"
  },
  "homepage": "https://github.com/jenniferlynparsons/plastic#readme",
  "dependencies": {
    "@babel/polyfill": "^7.4.3",
    "body-parser": "^1.18.3",
    "is-empty": "^1.2.0",
    "npm": "^6.9.0",
    "ts-jest": "^26.4.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.12.1",
    "@babel/core": "^7.12.3",
    "@babel/plugin-transform-runtime": "^7.4.4",
    "@babel/preset-env": "^7.4.3",
    "@babel/preset-typescript": "^7.12.1",
    "babel-eslint": "^10.0.1",
    "babel-jest": "^24.9.0",
    "babel-loader": "^8.0.5",
    "babel-plugin-dynamic-import-node": "^2.2.0",
    "babel-plugin-transform-class-properties": "^6.24.1",
    "babel-plugin-transform-decorators-legacy": "^1.3.5",
    "babel-plugin-transform-export-extensions": "^6.22.0",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "eslint": "^5.16.0",
    "eslint-config-prettier": "^4.1.0",
    "eslint-plugin-import": "^2.16.0",
    "eslint-plugin-prettier": "^3.0.1",
    "html-webpack-plugin": "^3.2.0",
    "jest": "^24.8.0",
    "jest-dom": "^3.5.0",
    "prettier": "^1.16.4",
    "typedoc": "^0.19.2",
    "typedoc-webpack-plugin": "^1.1.4",
    "webpack": "^4.29.6",
    "webpack-cli": "^3.3.0",
    "webpack-dev-server": "^3.3.1"
  },
  "jest": {
    "clearMocks": true,
    "collectCoverageFrom": [
      "<rootDir>"
    ],
    "coverageDirectory": "coverage",
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "setupFiles": [],
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/__tests__/**/*.js?(x)",
      "**/?(*.)+(spec|test).js?(x)"
    ],
    "testPathIgnorePatterns": [
      "\\\\node_modules\\\\"
    ],
    "testURL": "http://localhost",
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/"
    ],
    "verbose": true,
    "moduleNameMapper": {
      "\\.(css|less|scss|sass|styl)$": "identity-obj-proxy"
    }
  }
}
